{
  "name": "poc-creator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:pages": "npm run build && npx gh-pages -d dist",
    "deploy:vercel": "npm run build && npx vercel --yes",
    "deploy:vercel:prod": "npm run build && npx vercel --prod --yes",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "vercel": "^51.6.1",
    "vite": "^6.3.2"
  }
}
